    "    'Error_%': ((y_test.iloc[:10].values - y_test_pred[:10]) / y_test.iloc[:10].values * 100).round(1)\n",
    "})\n",
    "\n",
    "print(sample_results.to_string(index=False))\n",
    "\n",
    "# Save evaluation results\n",
    "evaluation_results = {\n",
    "    'test_mse': test_mse,\n",
    "    'test_rmse': test_rmse,\n",
    "    'test_mae': test_mae,\n",
    "    'test_r2': test_r2,\n",
    "    'mape': mape,\n",
    "    'accuracy_10pct': accuracy_10pct,\n",
    "    'accuracy_20pct': accuracy_20pct,\n",
    "    'accuracy_30pct': accuracy_30pct\n",
    "}\n",
    "\n",
    "pd.DataFrame([evaluation_results]).to_csv('outputs/evaluation_metrics.csv', index=False)\n",
    "print(f\"\\n💾 Evaluation metrics saved: outputs/evaluation_metrics.csv\")"
   ]
