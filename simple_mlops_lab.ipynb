    "# Cell 7: Model Evaluation\n",
    "print(\"📊 Evaluating model on test data...\")\n",
    "\n",
    "# Test predictions\n",
    "y_test_pred = model.predict(X_test)\n",
    "\n",
    "# Calculate metrics\n",
    "test_mse = mean_squared_error(y_test, y_test_pred)\n",
    "test_mae = mean_absolute_error(y_test, y_test_pred)\n",
    "test_r2 = r2_score(y_test, y_test_pred)\n",
    "test_rmse = np.sqrt(test_mse)\n",
    "\n",
    "# Calculate percentage-based metrics\n",
    "mape = np.mean(np.abs((y_test - y_test_pred) / y_test)) * 100\n",
    "median_error = np.median(np.abs(y_test - y_test_pred))\n",
    "\n",
    "print(f\"\\n🎯 Test Results:\")\n",
    "print(f\"   MSE: ${test_mse:,.0f}\")\n",
    "print(f\"   RMSE: ${test_rmse:,.0f}\")\n",
    "print(f\"   MAE: ${test_mae:,.0f}\")\n",
    "print(f\"   R² Score: {test_r2:.4f}\")\n",
    "print(f\"   MAPE: {mape:.2f}%\")\n",
    "print(f\"   Median Error: ${median_error:,.0f}\")\n",
    "\n",
    "# Accuracy within percentage ranges\n",
    "accuracy_10pct = np.mean(np.abs((y_test - y_test_pred) / y_test) <= 0.10) * 100\n",
    "accuracy_20pct = np.mean(np.abs((y_test - y_test_pred) / y_test) <= 0.20) * 100\n",
    "accuracy_30pct = np.mean(np.abs((y_test - y_test_pred) / y_test) <= 0.30) * 100\n",
    "\n",
    "print(f\"\\n📈 Prediction Accuracy:\")\n",
    "print(f\"   Within 10%: {accuracy_10pct:.1f}% of predictions\")\n",
    "print(f\"   Within 20%: {accuracy_20pct:.1f}% of predictions\")\n",
    "print(f\"   Within 30%: {accuracy_30pct:.1f}% of predictions\")\n",
    "\n",
    "# Sample predictions\n",
    "print(f\"\\n🔍 Sample Predictions:\")\n",
    "sample_results = pd.DataFrame({\n",
    "    'Actual': y_test.iloc[:10].values,\n",
    "    'Predicted': y_test_pred[:10].astype(int),\n",
