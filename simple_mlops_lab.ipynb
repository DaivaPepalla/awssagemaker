    "# Cell 9: Model Inference Function\n",
    "def predict_house_price(model, **house_features):\n",
    "    \"\"\"Predict house price given features\"\"\"\n",
    "    \n",
    "    # Default values for missing features\n",
    "    default_features = {\n",
    "        'bedrooms': 3,\n",
    "        'bathrooms': 2,\n",
    "        'sqft_living': 2000,\n",
    "        'sqft_lot': 5000,\n",
    "        'floors': 1,\n",
    "        'waterfront': 0,\n",
    "        'view': 0,\n",
    "        'condition': 3,\n",
    "        'grade': 7,\n",
    "        'yr_built': 1990,\n",
    "        'yr_renovated': 0\n",
    "    }\n",
    "    \n",
    "    # Update with provided features\n",
    "    default_features.update(house_features)\n",
    "    \n",
    "    # Create input array in correct order\n",
    "    input_data = [[default_features[feature] for feature in features]]\n",
    "    \n",
    "    # Make prediction\n",
    "    prediction = model.predict(input_data)[0]\n",
    "    \n",
    "    return prediction\n",
    "\n",
    "# Example predictions\n",
    "print(\"🏠 Example House Price Predictions:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# Example 1: Modest house\n",
    "modest_house = {\n",
    "    'bedrooms': 2,\n",
    "    'bathrooms': 1,\n",
    "    'sqft_living': 1200,\n",
    "    'sqft_lot': 3000,\n",
    "    'floors': 1,\n",
    "    'waterfront': 0,\n",
    "    'view': 0,\n",
    "    'condition': 3,\n",
    "    'grade': 6,\n",
    "    'yr_built': 1980,\n",
    "    'yr_renovated': 0\n",
    "}\n",
    "\n",
    "price1 = predict_house_price(model, **modest_house)\n",
    "print(f\"Modest House: ${price1:,.0f}\")\n",
    "print(f\"  Features: {modest_house}\")\n",
    "\n",
    "# Example 2: Luxury house\n",
    "luxury_house = {\n",
    "    'bedrooms': 5,\n",
    "    'bathrooms': 4,\n",
    "    'sqft_living': 4500,\n",
    "    'sqft_lot': 15000,\n",
    "    'floors': 2,\n",
    "    'waterfront': 1,\n",
    "    'view': 4,\n",
    "    'condition': 5,\n",
    "    'grade': 11,\n",
    "    'yr_built': 2010,\n",
    "    'yr_renovated': 2020\n",
    "}\n",
    "\n",
    "price2 = predict_house_price(model, **luxury_house)\n",
    "print(f\"\\nLuxury House: ${price2:,.0f}\")\n",
    "print(f\"  Features: {luxury_house}\")\n",
    "\n",
    "# Example 3: Average house\n",
    "average_house = {\n",
    "    'bedrooms': 3,\n",
    "    'bathrooms': 2,\n",
    "    'sqft_living': 2200,\n",
    "    'sqft_lot': 6000,\n",
    "    'floors': 1,\n",
    "    'waterfront': 0,\n",
    "    'view': 1,\n",
    "    'condition': 4,\n",
    "    'grade': 8,\n",
    "    'yr_built': 2000,\n",
    "    'yr_renovated': 0\n",
    "}\n",
    "\n",
    "price3 = predict_house_price(model, **average_house)\n",
    "print(f\"\\nAverage House: ${price3:,.0f}\")\n",
