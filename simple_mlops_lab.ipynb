    "# Cell 2: Imports and Configuration\n",
    "import os\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import joblib\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error\n",
    "\n",
    "# Configuration\n",
    "RANDOM_STATE = 42\n",
    "TEST_SIZE = 0.2\n",
    "MODEL_NAME = \"house_price_model\"\n",
    "\n",
    "# Create directories\n",
    "os.makedirs('data', exist_ok=True)\n",
    "os.makedirs('models', exist_ok=True)\n",
    "os.makedirs('outputs', exist_ok=True)\n",
    "\n",
    "print(\"✅ Environment setup complete\")\n",
    "print(f\"📁 Working directory: {os.getcwd()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3: Data Generation (Realistic House Price Dataset)\n",
    "def create_house_price_dataset(n_samples=5000):\n",
    "    \"\"\"Create a realistic house price dataset\"\"\"\n",
    "    np.random.seed(RANDOM_STATE)\n",
    "    \n",
    "    print(f\"🏠 Generating {n_samples:,} house price samples...\")\n",
    "    \n",
    "    # Generate realistic features\n",
    "    bedrooms = np.random.choice([1,2,3,4,5,6], n_samples, p=[0.05,0.15,0.35,0.30,0.12,0.03])\n",
    "    bathrooms = np.random.choice([1,2,3,4], n_samples, p=[0.20,0.45,0.25,0.10])\n",
    "    \n",
    "    # Square footage with realistic distribution\n",
    "    sqft_living = np.random.lognormal(mean=7.5, sigma=0.5, size=n_samples).astype(int)\n",
    "    sqft_living = np.clip(sqft_living, 500, 8000)\n",
    "    \n",
    "    sqft_lot = sqft_living + np.random.exponential(2000, n_samples).astype(int)\n",
    "    sqft_lot = np.clip(sqft_lot, sqft_living, 50000)\n",
    "    \n",
    "    floors = np.random.choice([1,2,3], n_samples, p=[0.60,0.35,0.05])\n",
    "    waterfront = np.random.choice([0,1], n_samples, p=[0.95,0.05])\n",
    "    view = np.random.choice([0,1,2,3,4], n_samples, p=[0.60,0.20,0.10,0.07,0.03])\n",
    "    condition = np.random.choice([1,2,3,4,5], n_samples, p=[0.05,0.10,0.50,0.30,0.05])\n",
    "    grade = np.random.choice(range(3,14), n_samples)\n",
    "    \n",
    "    # Year built with realistic distribution\n",
    "    yr_built = np.random.choice(range(1900, 2024), n_samples, \n",
    "                               p=np.concatenate([\n",
    "                                   np.full(50, 0.002),  # 1900-1949\n",
    "                                   np.full(30, 0.015),  # 1950-1979\n",
    "                                   np.full(30, 0.020),  # 1980-2009\n",
    "                                   np.full(14, 0.025)   # 2010-2023\n",
    "                               ]))\n",
    "    \n",
    "    yr_renovated = np.random.choice([0] + list(range(1950, 2024)), n_samples, \n",
    "                                   p=[0.75] + [0.25/74]*74)\n",
    "    \n",
    "    # Calculate price based on realistic factors\n",
    "    price_base = (\n",
    "        bedrooms * 35000 +\n",
    "        bathrooms * 25000 +\n",
    "        sqft_living * 200 +\n",
    "        sqft_lot * 2 +\n",
    "        floors * 15000 +\n",
    "        waterfront * 300000 +\n",
    "        view * 25000 +\n",
    "        condition * 20000 +\n",
    "        (grade - 7) * 30000 +\n",
    "        np.maximum(0, 2024 - yr_built) * (-800)  # Age depreciation\n",
    "    )\n",
    "    \n",
    "    # Add market variation and noise\n",
    "    market_factor = np.random.normal(1.0, 0.15, n_samples)\n",
    "    noise = np.random.normal(0, 50000, n_samples)\n",
    "    \n",
    "    price = (price_base * market_factor + noise)\n",
    "    price = np.clip(price, 100000, 5000000).astype(int)\n",
    "    \n",
    "    # Create DataFrame\n",
    "    data = {\n",
    "        'bedrooms': bedrooms,\n",
    "        'bathrooms': bathrooms,\n",
    "        'sqft_living': sqft_living,\n",
    "        'sqft_lot': sqft_lot,\n",
    "        'floors': floors,\n",
    "        'waterfront': waterfront,\n",
    "        'view': view,\n",
    "        'condition': condition,\n",
    "        'grade': grade,\n",
    "        'yr_built': yr_built,\n",
    "        'yr_renovated': yr_renovated,\n",
    "        'price': price\n",
    "    }\n",
    "    \n",
    "    df = pd.DataFrame(data)\n",
    "    \n",
    "    print(f\"✅ Dataset created: {df.shape}\")\n",
    "    print(f\"💰 Price range: ${df['price'].min():,} - ${df['price'].max():,}\")\n",
    "    print(f\"📊 Average price: ${df['price'].mean():,.0f}\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Generate dataset\n",
    "df = create_house_price_dataset()\n",
    "\n",
    "# Display basic info\n",
    "print(\"\\n📋 Dataset Info:\")\n",
    "print(df.info())\n",
    "\n",
    "print(\"\\n📈 Price Statistics:\")\n",
    "print(df['price'].describe())\n",
    "\n",
    "df.head()"
   ]
  },
  {
