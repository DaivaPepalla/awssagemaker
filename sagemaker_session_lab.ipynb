    "# Cell 2: Imports and SageMaker Configuration with Real AWS Role\n",
    "import os\n",
    "import boto3\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Set environment variables\n",
    "os.environ['TOKENIZERS_PARALLELISM'] = 'false'\n",
    "os.environ['HF_HUB_DISABLE_PROGRESS_BARS'] = '1'\n",
    "\n",
    "# Import SageMaker components\n",
    "try:\n",
    "    from sagemaker.session import Session\n",
    "    from sagemaker import get_execution_role\n",
    "    sagemaker_available = True\n",
    "    print(\"✅ SageMaker imports successful\")\n",
    "except ImportError:\n",
    "    try:\n",
    "        from sagemaker import Session, get_execution_role\n",
    "        sagemaker_available = True\n",
    "        print(\"✅ SageMaker imports successful (legacy)\")\n",
    "    except ImportError:\n",
    "        print(\"❌ SageMaker imports failed - using fallback\")\n",
    "        Session = None\n",
    "        get_execution_role = None\n",
    "        sagemaker_available = False\n",
    "\n",
    "# Get AWS account info\n",
    "try:\n",
    "    sts = boto3.client('sts')\n",
    "    identity = sts.get_caller_identity()\n",
    "    account_id = identity['Account']\n",
    "    print(f\"🔍 AWS Account ID: {account_id}\")\n",
    "except Exception as e:\n",
    "    print(f\"⚠️  Could not get AWS account: {e}\")\n",
    "    account_id = \"YOUR_ACCOUNT_ID\"  # Replace with your actual account ID\n",
    "\n",
    "# SageMaker session and role setup\n",
    "region = \"us-east-1\"  # Change to your preferred region\n",
    "# Replace with your actual SageMaker execution role ARN\n",
    "role = f\"arn:aws:iam::{account_id}:role/service-role/AmazonSageMaker-ExecutionRole-20241209T141456\"\n",
    "sess = None\n",
    "\n",
    "if sagemaker_available and Session:\n",
    "    try:\n",
    "        print(\"🚀 Attempting to create SageMaker session...\")\n",
    "        sess = Session()\n",
    "        region = sess.boto_region_name\n",
    "        \n",
    "        # Try to get execution role from SageMaker environment\n",
    "        if get_execution_role:\n",
    "            try:\n",
    "                role = get_execution_role()\n",
    "                print(f\"✅ Got execution role from SageMaker: {role}\")\n",
    "            except Exception:\n",
    "                print(f\"📝 Using configured role: {role}\")\n",
    "        \n",
    "        print(f\"✅ SageMaker session created successfully\")\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"⚠️  SageMaker session creation failed: {e}\")\n",
    "        print(f\"📝 Using fallback configuration\")\n",
    "        sess = None\n",
    "\n",
    "# S3 bucket configuration\n",
    "bucket = f\"sagemaker-{region}-{account_id}\"  # Standard SageMaker bucket format\n",
    "prefix = \"house-price-prediction\"\n",
    "\n",
    "print(f\"\\n📊 Configuration Summary:\")\n",
    "print(f\"   Region: {region}\")\n",
    "print(f\"   Role: {role}\")\n",
    "print(f\"   Bucket: {bucket}\")\n",
    "print(f\"   SageMaker Session: {'✅ Active' if sess else '❌ Local Mode'}\")"
   ]
