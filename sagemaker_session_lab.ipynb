    "# Cell 3: Load and Clean Dataset\n",
    "def load_dataset_safely():\n",
    "    try:\n",
    "        from datasets import load_dataset\n",
    "        print(\"📥 Loading dataset from Hugging Face...\")\n",
    "        ds = load_dataset(\"Saathwik56/houseprice\")\n",
    "        df = ds[\"train\"].to_pandas()\n",
    "        print(f\"✅ Dataset loaded successfully: {df.shape}\")\n",
    "        return df, \"huggingface\"\n",
    "    except Exception as e:\n",
    "        print(f\"⚠️  Hugging Face loading failed: {e}\")\n",
    "        print(\"🔄 Creating sample house price data...\")\n",
    "        \n",
    "        np.random.seed(42)\n",
    "        n_samples = 5000  # Larger dataset for better training\n",
    "        \n",
    "        # Generate realistic correlated features\n",
    "        bedrooms = np.random.choice([1,2,3,4,5,6], n_samples, p=[0.05,0.15,0.35,0.30,0.12,0.03])\n",
    "        bathrooms = np.random.choice([1,2,3,4], n_samples, p=[0.20,0.45,0.25,0.10])\n",
    "        sqft_living = np.random.normal(2000, 800, n_samples).clip(500, 8000).astype(int)\n",
    "        sqft_lot = (sqft_living * np.random.uniform(1.2, 3.0, n_samples)).astype(int)\n",
    "        floors = np.random.choice([1,2,3], n_samples, p=[0.60,0.35,0.05])\n",
    "        waterfront = np.random.choice([0,1], n_samples, p=[0.95,0.05])\n",
    "        view = np.random.choice([0,1,2,3,4], n_samples, p=[0.60,0.20,0.10,0.07,0.03])\n",
    "        condition = np.random.choice([1,2,3,4,5], n_samples, p=[0.05,0.10,0.50,0.30,0.05])\n",
    "        grade = np.random.choice(range(3,14), n_samples)\n",
    "        yr_built = np.random.randint(1900, 2024, n_samples)\n",
    "        yr_renovated = np.random.choice([0] + list(range(1950, 2024)), n_samples, p=[0.75] + [0.25/74]*74)\n",
    "        \n",
    "        # Calculate price based on features (more realistic)\n",
    "        price_base = (\n",
    "            bedrooms * 45000 +\n",
    "            bathrooms * 25000 +\n",
    "            sqft_living * 180 +\n",
    "            floors * 15000 +\n",
    "            waterfront * 200000 +\n",
    "            view * 30000 +\n",
    "            condition * 20000 +\n",
    "            grade * 15000 +\n",
    "            np.maximum(0, 2024 - yr_built) * (-500)  # Age depreciation\n",
    "        )\n",
    "        \n",
    "        # Add noise and ensure realistic range\n",
    "        price = (price_base + np.random.normal(0, 80000, n_samples)).clip(80000, 5000000).astype(int)\n",
    "        \n",
    "        sample_data = {\n",
    "            'bedrooms': bedrooms,\n",
    "            'bathrooms': bathrooms,\n",
    "            'sqft_living': sqft_living,\n",
    "            'sqft_lot': sqft_lot,\n",
    "            'floors': floors,\n",
    "            'waterfront': waterfront,\n",
    "            'view': view,\n",
    "            'condition': condition,\n",
    "            'grade': grade,\n",
    "            'yr_built': yr_built,\n",
    "            'yr_renovated': yr_renovated,\n",
    "            'price': price\n",
    "        }\n",
    "        \n",
    "        df = pd.DataFrame(sample_data)\n",
    "        print(f\"✅ Sample dataset created: {df.shape}\")\n",
    "        return df, \"synthetic\"\n",
    "\n",
    "# Load dataset\n",
    "df, data_source = load_dataset_safely()\n",
    "\n",
    "# Clean column names\n",
    "df.columns = [c.strip().lower().replace(\" \", \"_\") for c in df.columns]\n",
    "\n",
    "print(f\"\\n📊 Dataset Summary:\")\n",
    "print(f\"   Source: {data_source}\")\n",
    "print(f\"   Shape: {df.shape}\")\n",
    "print(f\"   Columns: {list(df.columns)}\")\n",
    "print(f\"\\n📈 Price Statistics:\")\n",
    "print(df['price'].describe())\n",
    "\n",
    "df.head()"
   ]
  },
