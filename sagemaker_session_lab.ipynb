    "# Cell 8: Model Evaluation\n",
    "import joblib\n",
    "from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "print(\"📊 Evaluating trained model...\")\n",
    "\n",
    "# Load model\n",
    "try:\n",
    "    model = joblib.load(\"model/model.joblib\")\n",
    "    print(\"✅ Model loaded successfully\")\n",
    "except:\n",
    "    print(\"❌ Could not load model from model/model.joblib\")\n",
    "    raise\n",
    "\n",
    "# Load test data\n",
    "test_data = pd.read_csv(\"data/test.csv\")\n",
    "target = \"price\"\n",
    "X_test = test_data.drop(columns=[target]).select_dtypes(include=['number'])\n",
    "y_test = test_data[target]\n",
    "\n",
    "print(f\"🧪 Test data: {X_test.shape[0]} samples, {X_test.shape[1]} features\")\n",
    "\n",
    "# Make predictions\n",
    "y_pred = model.predict(X_test)\n",
    "\n",
    "# Calculate comprehensive metrics\n",
    "mse = mean_squared_error(y_test, y_pred)\n",
    "mae = mean_absolute_error(y_test, y_pred)\n",
    "r2 = r2_score(y_test, y_pred)\n",
    "rmse = np.sqrt(mse)\n",
    "\n",
    "# Calculate percentage errors\n",
    "mape = np.mean(np.abs((y_test - y_pred) / y_test)) * 100\n",
    "median_error = np.median(np.abs(y_test - y_pred))\n",
    "\n",
    "print(f\"\\n🎯 Test Results:\")\n",
    "print(f\"   MSE: ${mse:,.0f}\")\n",
    "print(f\"   RMSE: ${rmse:,.0f}\")\n",
    "print(f\"   MAE: ${mae:,.0f}\")\n",
    "print(f\"   R² Score: {r2:.4f}\")\n",
    "print(f\"   MAPE: {mape:.2f}%\")\n",
    "print(f\"   Median Error: ${median_error:,.0f}\")\n",
    "\n",
    "# Sample predictions with analysis\n",
    "print(f\"\\n🔍 Sample Predictions Analysis:\")\n",
    "sample_size = min(10, len(y_test))\n",
    "comparison = pd.DataFrame({\n",
    "    'Actual': y_test.iloc[:sample_size].values,\n",
    "    'Predicted': y_pred[:sample_size].astype(int),\n",
