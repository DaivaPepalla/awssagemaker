    "# Cell 4: Data Cleaning and Splitting\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "print(\"🧹 Cleaning and splitting data...\")\n",
    "\n",
    "# Identify target column\n",
    "target = \"price\"\n",
    "print(f\"🎯 Target column: {target}\")\n",
    "\n",
    "# Remove any missing values\n",
    "initial_shape = df.shape\n",
    "df = df.dropna(subset=[target])\n",
    "print(f\"📊 Removed {initial_shape[0] - df.shape[0]} rows with missing target\")\n",
    "\n",
    "# Clean numeric columns\n",
    "for col in df.columns:\n",
    "    if df[col].dtype == \"object\":\n",
    "        # Remove commas and convert to numeric\n",
    "        temp_col = df[col].astype(str).str.replace(\",\", \"\", regex=False)\n",
    "        df[col] = pd.to_numeric(temp_col, errors=\"ignore\")\n",
    "\n",
    "# Split the data with stratification for better distribution\n",
    "price_bins = pd.qcut(df[target], q=5, labels=['low', 'med_low', 'medium', 'med_high', 'high'])\n",
    "train_df, test_df = train_test_split(\n",
    "    df, \n",
    "    test_size=0.2, \n",
    "    random_state=42, \n",
    "    stratify=price_bins\n",
    ")\n",
    "\n",
    "# Create local directory and save files\n",
    "os.makedirs(\"data\", exist_ok=True)\n",
    "train_df.to_csv(\"data/train.csv\", index=False)\n",
    "test_df.to_csv(\"data/test.csv\", index=False)\n",
    "\n",
    "print(f\"\\n✅ Data split and saved:\")\n",
    "print(f\"   📁 Training: {len(train_df):,} rows ({len(train_df)/len(df)*100:.1f}%)\")\n",
    "print(f\"   📁 Testing: {len(test_df):,} rows ({len(test_df)/len(df)*100:.1f}%)\")\n",
    "print(f\"   💾 Files: data/train.csv, data/test.csv\")"
   ]
  },
