    "\n",
    "    # Prepare features and target\n",
    "    target = \"price\"\n",
    "    X = df.drop(columns=[target]).select_dtypes(include=['number'])\n",
    "    y = df[target]\n",
    "    \n",
    "    print(f\"🎯 Target: {target}\")\n",
